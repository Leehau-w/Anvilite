{
  "appId": "com.anvilite.app",
  "productName": "Anvilite",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "signAndEditExecutable": false
  },
  "afterPack": "./scripts/after-pack.cjs",
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "shortcutName": "Anvilite",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico"
  },
  "portable": {
    "artifactName": "Anvilite-${version}-portable.exe"
  },
  "extraResources": [
    { "from": "build/icon.ico", "to": "build/icon.ico" }
  ]
}
